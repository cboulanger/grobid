# Docker Hub credentials
# Get a token at https://hub.docker.com/settings/security (use "Access Token", not your password)
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token

# Dockerfile variant to build — one of:
#   Dockerfile.trainer.crf       local CRF-only training
#   Dockerfile.trainer.hpc       HPC with full DeLFT/GPU support
#   Dockerfile.trainer.hpc.crf   HPC CRF-only training
DOCKERFILE=Dockerfile.trainer.hpc.crf

# Image name on Docker Hub (without username prefix)
IMAGE_NAME=grobid-trainer

# GROBID source version embedded in the image label
GROBID_VERSION=0.8.3-SNAPSHOT

# Tag for the pushed image (defaults to GROBID_VERSION if left empty)
IMAGE_TAG=latest

# Target platform — HPC clusters are almost always amd64
# BUILD_PLATFORM=linux/amd64
